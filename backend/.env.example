# ============================================================
# NewsFlow Backend — Environment Variables
# ============================================================
# Copy to .env and fill in values:
#   cp .env.example .env
#
# Start with docker-compose (includes PostgreSQL + Redis):
#   docker-compose up -d
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=NewsFlow
APP_VERSION=1.0.0
ENVIRONMENT=development          # development | staging | production
DEBUG=true
HOST=0.0.0.0
PORT=8000
WORKERS=4
ENABLE_DEMO_SEED=false         # docker-compose startup: true to run scripts/seed_demo_all.py

# ── Database (PostgreSQL) ────────────────────────────────────
# Local (docker-compose provides postgres:postgres@localhost:5432/newflow)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/newflow
# Supabase production:
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
# DATABASE_READ_URLS=              # Optional: comma-separated read replica URLs

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=100
REDIS_SOCKET_TIMEOUT=5
REDIS_DECODE_RESPONSES=true
# REDIS_SENTINEL_URLS=             # Optional: host1:26379,host2:26379
# REDIS_SENTINEL_MASTER=mymaster

# ── AI Services ──────────────────────────────────────────────
# OpenAI-compatible API (required — daily summary generation)
# OpenAI: leave OPENAI_BASE_URL empty
# DeepSeek: OPENAI_BASE_URL=https://api.deepseek.com  OPENAI_MODEL=deepseek-chat
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=150
OPENAI_TEMPERATURE=0.3

# Anthropic (optional — deep analysis for premium users)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Rate limits
AI_MAX_CONCURRENT=50
AI_REQUESTS_PER_MINUTE=500

# Budget control
AI_DAILY_BUDGET_USD=5.0
AI_MONTHLY_BUDGET_USD=100.0

# ── Security ─────────────────────────────────────────────────
# Generate a key: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-random-32-chars-minimum
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=*                   # Production: https://newflow.app

# ── Supabase (Auth) ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Freemium ─────────────────────────────────────────────────
FREE_MAX_TOPIC_SUBSCRIPTIONS=5
FREE_DAILY_ARTICLE_VIEWS=20
PREMIUM_PRODUCT_ID=newsflow_premium_monthly
ALLOW_DEV_PURCHASE_VERIFY=false

# ── Firebase (Push Notifications) ────────────────────────────
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
# FIREBASE_CREDENTIALS_JSON=     # Alternative: inline JSON for CI/CD
DAILY_BRIEFING_HOUR_UTC=8        # Cron hour (UTC) for daily briefing push

# ── Storage ──────────────────────────────────────────────────
STORAGE_TYPE=local               # local | s3 | gcs
STORAGE_BASE_PATH=./uploads

# S3 (optional)
# S3_BUCKET=newflow-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT_URL=

# ── Analytics ────────────────────────────────────────────────
ANALYTICS_RETENTION_DAYS=90
# Optional: protect dashboard/query endpoints and /web/analytics
# ANALYTICS_DASHBOARD_TOKEN=change-me
# Comma-separated admin emails allowed via Bearer JWT (email claim)
# ANALYTICS_ADMIN_EMAILS=admin@example.com
# Or grant users.is_admin=true in DB; JWT will include is_admin claim

# ── Celery (optional, disabled by default) ───────────────────
USE_CELERY=false
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=4
