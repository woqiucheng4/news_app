[run]
# Unit-test coverage gate focuses on deterministic business logic.
# Infra adapters are validated by integration/runtime checks.
omit =
    core/ai.py
    core/cache.py
    core/database.py
    core/storage.py
    # Phase 4+ modules: covered by dedicated tests; excluded from Phase 1 UAT gate (01-UAT test 22)
    services/daily_briefing.py
